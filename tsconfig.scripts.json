{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2020",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["scripts/**/*"]
}
